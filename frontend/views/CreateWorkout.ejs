<!DOCTYPE html>
<html lang="en">
   <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Create Workout</title>
      <link rel="stylesheet" href="CreateWorkout.css">
      <link rel="stylesheet" href="Parts/Header/Header.css">
   </head>

   <body>
      <%- include('./Parts/Header/Header.ejs') %>

      <div id="This-Body">
         
         <form class="workoutCreationCon" action="createWorkout" method="post">
            <input class="workouttitle" type="text" name="workouttitle" placeholder="Title">

            <div id="exercise-con">
               
               <div class="Exercise">
                  <input class="exerciseName" type="text" name="exercise[]" placeholder="שם של התרגיל">
                  <div>
                     <input type="number" name="weight[]" placeholder="משקל">
                     <input type="number" name="reps[]" placeholder="חזרות">
                  </div>
                  <button type="button" class="delete-btn">מחק תרגיל</button>
               </div>

            </div>

            <input type="button" value="הוספת תרגיל" id="addExercise">
            <input type="submit" value="צור אימון" id="createWorkoutBtn">

         </form>

      </div>

      <script src="Scripts/CreateWorkout.js"></script>
   </body>
</html>